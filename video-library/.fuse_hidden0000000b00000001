    <!-- Folder create/edit modal -->
    <div class="modal" id="folderModal">
        <div class="modal-content">
            <h2 id="folderModalTitle">Create Folder</h2>
            <div class="modal-field">
                <label>Folder name</label>
                <input type="text" id="folderNameInput" placeholder="e.g. Tutorials, Favorites…">
            </div>
            <div class="modal-field">
                <label>Notes — describe what this folder is for</label>
                <textarea id="folderNotesInput" placeholder="e.g. Beginner guitar lessons from YouTube…"></textarea>
            </div>
            <div class="modal-field">
                <label>Parent folder</label>
                <select id="parentSelect">
                    <option value="">Root</option>
                </select>
            </div>
            <div class="modal-actions">
                <button onclick="closeModal()" class="btn-secondary">Cancel</button>
                <button onclick="saveFolderModal()">Save</button>

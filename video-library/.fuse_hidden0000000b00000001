    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);
            color: #e0e0e0;
            min-height: 100vh;
            padding: 20px;
        }
        .container { max-width: 1400px; margin: 0 auto; }
        .app-header {
            background: rgba(79, 70, 229, 0.1);
            backdrop-filter: blur(10px);
            padding: 20px;
            border-radius: 12px;
            margin-bottom: 30px;
            border: 1px solid rgba(79, 70, 229, 0.3);
        }
        .app-header h1 { color: #4f46e5; margin-bottom: 15px; font-size: 2em; }
        .controls { display: flex; gap: 10px; flex-wrap: wrap; }
        input[type="url"], input[type="text"] {
            flex: 1;
            min-width: 200px;
            padding: 12px;
            border: 2px solid rgba(79, 70, 229, 0.3);
            border-radius: 8px;
            background: rgba(255, 255, 255, 0.05);
            color: #e0e0e0;
            font-size: 14px;
        }
        button {
            padding: 12px 24px;
            background: linear-gradient(135deg, #4f46e5 0%, #6366f1 100%);
            color: white;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 600;
            transition: all 0.3s;
        }
        button:hover { transform: translateY(-2px); }
        .btn-secondary { background: linear-gradient(135deg, #374151 0%, #4b5563 100%); }
        .btn-danger { background: linear-gradient(135deg, #dc2626 0%, #ef4444 100%); }
        .btn-small { padding: 6px 12px; font-size: 12px; }
        .player-section {
            background: rgba(0, 0, 0, 0.4);
            padding: 20px;
            border-radius: 12px;
            margin-bottom: 30px;
            border: 1px solid rgba(79, 70, 229, 0.2);
        }
        .player-section .video-card-title-bottom,
        .player-section .video-progress-bar,
        .player-section .video-resume-badge,
        .player-section .video-thumbnail-container {
            display: none !important;
        }
        .video-wrapper {
            position: relative;
            padding-bottom: 56.25%;
            height: 0;
            overflow: hidden;
            border-radius: 8px;
            background: #000;
            margin-bottom: 15px;
            isolation: isolate;
        }
        .video-wrapper iframe, .video-wrapper video {
            position: absolute;
            top: 0; left: 0;
            width: 100%; height: 100%;
            border: none;
        }
        .video-wrapper::before, .video-wrapper::after { display: none !important; }
        #videoWrapper > *:not(iframe):not(video) { display: none !important; }

        /* Editable video title in player */
        .video-title {
            font-size: 1.4em;
            margin: 10px 0 4px;
            padding: 6px 8px;
            border-radius: 6px;
            outline: none;
            border: 1px solid transparent;
            cursor: text;
            transition: border-color 0.2s, background 0.2s;
        }
        .video-title:hover { background: rgba(255,255,255,0.04); border-color: rgba(79,70,229,0.3); }
        .video-title:focus { background: rgba(255,255,255,0.06); border-color: rgba(79,70,229,0.5); }
        .video-title-hint { font-size: 11px; color: #6b7280; margin-bottom: 8px; padding-left: 8px; }
        .video-info { margin-top: 0; }

        textarea {
            width: 100%;
            min-height: 80px;
            padding: 12px;
            border: 2px solid rgba(79, 70, 229, 0.3);
            border-radius: 8px;
            background: rgba(255, 255, 255, 0.05);
            color: #e0e0e0;
            font-family: inherit;
            resize: vertical;
        }
        .playlist-controls { display: flex; gap: 10px; margin-top: 15px; flex-wrap: wrap; align-items: center; }
        .library-section { display: grid; grid-template-columns: 300px 1fr; gap: 20px; margin-top: 30px; }
        .sidebar {
            background: rgba(0, 0, 0, 0.3);
            padding: 20px;
            border-radius: 12px;
            border: 1px solid rgba(79, 70, 229, 0.2);
            max-height: 80vh;
            overflow-y: auto;
        }
        .folder-item {
            margin: 3px 0;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 6px;
            transition: all 0.2s;
            border: 1px solid transparent;
        }
        .folder-item:hover {
            background: rgba(79, 70, 229, 0.2);
            border-color: rgba(79, 70, 229, 0.3);
        }
        .folder-item.active {
            background: rgba(79, 70, 229, 0.3);
            border-left: 3px solid #4f46e5;
        }
        .folder-item.drag-over {
            background: rgba(79, 70, 229, 0.5);

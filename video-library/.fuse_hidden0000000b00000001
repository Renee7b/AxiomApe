<body>
    <div class="container">
        <div class="app-header">
            <h1>🎬 Video Player &amp; Library</h1>
            <div class="controls">
                <input type="url" id="videoUrl" placeholder="Paste YouTube, Vimeo, or Dailymotion URL…">
                <button onclick="addVideo()">Add Video</button>
                <button onclick="createFolder()" class="btn-secondary">New Folder</button>
                <button onclick="exportData()" class="btn-secondary">Export</button>
                <button onclick="document.getElementById('importInput').click()" class="btn-secondary">Import</button>
            </div>
        </div>

        <!-- Player -->
        <div class="player-section" id="playerSection" style="display: none;">
            <div class="video-wrapper" id="videoWrapper"></div>
            <div class="video-info">
                <div class="video-title" id="videoTitle" contenteditable="true" spellcheck="false" onblur="saveCurrentTitle()"></div>
                <div class="video-title-hint">✏️ Click title above to rename</div>
                <textarea id="videoNotes" placeholder="Add notes about this video…" onchange="saveCurrentNotes()"></textarea>
                <div class="playlist-controls">
                    <button onclick="prevVideo()">⏮ Prev</button>
                    <button onclick="nextVideo()">Next ⏭</button>
                    <button onclick="stopPlaylist()" class="btn-danger">⏹ Stop</button>
                    <button onclick="toggleShuffle()" class="btn-secondary" id="shuffleBtn">🔀 Shuffle</button>
                    <span id="playlistInfo" style="color: #9ca3af; font-size: 14px;"></span>
                </div>
            </div>
        </div>

        <!-- Library -->
        <div class="library-section">
            <div class="sidebar">
                <h2 style="margin-bottom: 12px;">Folders</h2>
                <input type="text" id="searchInput" placeholder="Search videos…"
                    style="width: 100%; margin-bottom: 15px; padding: 10px; background: rgba(255,255,255,0.05); border: 2px solid rgba(79,70,229,0.3); border-radius: 8px; color: #e0e0e0;"
                    oninput="renderVideos()">
                <div id="folderTree"></div>
            </div>
            <div id="videoGrid" class="video-grid">
                <div class="empty-state">
                    <h3>Welcome to Your Video Library</h3>
                    <p>Select a folder to view videos, or add a new video to get started.</p>
                </div>
            </div>
